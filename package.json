{
  "name": "checkhost-ts",
  "version": "0.1.0",
  "description": "Lightweight TypeScript wrapper for the check-host.net API",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "keywords": [
      "checkhost",
      "check-host.net",
      "api",
      "wrapper",
      "typescript"
  ],
  "homepage": "https://github.com/unicodick/checkhost-ts#readme",
  "repository": {
      "type": "git",
      "url": "git+https://github.com/unicodick/checkhost-ts.git"
  },
  "bugs": {
      "url": "https://github.com/unicodick/checkhost-ts/issues"
  },
  "sideEffects": false,
  "scripts": {
    "build:js": "bun build ./index.ts --outdir ./dist --target node",
    "build:types": "bunx tsc -p tsconfig.build.json",
    "build": "bun run build:js && bun run build:types",
    "typecheck": "bunx tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "type": "module",
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.2"
  }
}
